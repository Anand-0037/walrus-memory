# Walrus Memory credentials — copy to .env.local and fill in.
# Get these from https://memory.walrus.xyz dashboard (Delegate Keys).
# .env.local is gitignored. NEVER commit real keys.

# Ed25519 delegate private key (hex). Server-side only.
MEMWAL_PRIVATE_KEY=

# MemWalAccount object ID (0x...).
MEMWAL_ACCOUNT_ID=

# Relayer URL (Mainnet).
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz
